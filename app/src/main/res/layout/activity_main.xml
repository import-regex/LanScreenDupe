<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#102210">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:minLines="3"
            android:text="Initializing..."
            android:textColor="#20FFC4"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/labelBitrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Bitrate"
            android:textColor="#A0A0A0"
            android:textAllCaps="true"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/statusText" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/bitrateToggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnBitrate5"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/labelBitrate">
            <Button android:id="@+id/btnBitrate1" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="1" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnBitrate2" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="2" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnBitrate5" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="5" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnBitrate16" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="16" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnBitrate32" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="32" android:textColor="#FFFFFF" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <EditText
            android:id="@+id/customBitrate"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="Custom Mbps"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#606060"
            android:backgroundTint="#20FFC4"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/bitrateToggleGroup" />

        <TextView
            android:id="@+id/suffixBitrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Mbps"
            android:textColor="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/customBitrate"
            app:layout_constraintStart_toEndOf="@id/customBitrate"
            app:layout_constraintTop_toTopOf="@id/customBitrate" />

        <TextView
            android:id="@+id/labelFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Framerate (FPS)"
            android:textColor="#A0A0A0"
            android:textAllCaps="true"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/customBitrate" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/fpsToggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnFps16"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/labelFps">
            <Button android:id="@+id/btnFps8" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="8" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnFps16" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="16" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnFps20" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="20" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnFps30" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="30" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnFps60" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="60" android:textColor="#FFFFFF" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <EditText
            android:id="@+id/customFps"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="Custom FPS"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#606060"
            android:backgroundTint="#20FFC4"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/fpsToggleGroup" />

        <TextView
            android:id="@+id/labelQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Quality (Downsampling)"
            android:textColor="#A0A0A0"
            android:textAllCaps="true"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/customFps" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/qualityToggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnQual100"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/labelQuality">
            <Button android:id="@+id/btnQual13" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="13%" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnQual25" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="25%" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnQual50" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="50%" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnQual67" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="67%" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnQual100" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="100%" android:textColor="#FFFFFF" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/qualityDisplayContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="1/"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/qualityToggleGroup" />

        <TextView
            android:id="@+id/qualityDenominator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="1"
            android:textColor="#20FFC4"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@id/qualityDisplayContainer"
            app:layout_constraintStart_toEndOf="@id/qualityDisplayContainer" />

        <TextView
            android:id="@+id/labelAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Audio Mode"
            android:textColor="#A0A0A0"
            android:textAllCaps="true"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/qualityDenominator" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/audioToggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnAudioOff"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/labelAudio">
            <Button android:id="@+id/btnAudioOff" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="OFF" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnAudioMic" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="MIC" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnAudioMicRaw" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="MIC (raw)" android:textColor="#FFFFFF" />
            <!--<Button android:id="@+id/btnAudioSpk" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="SPK" android:textColor="#FFFFFF" />-->
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccessibility"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Grant Remote Control Permission"
            android:textColor="#20FFC4"
            app:strokeColor="#ff3055"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/audioToggleGroup" />


        <TextView
            android:id="@+id/labelMagic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="lock tap coordinates after first click?"
            android:textColor="#A0A0A0"
            android:textAllCaps="true"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/btnAccessibility" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/coordinateLocking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnNo"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintTop_toBottomOf="@id/labelMagic">
            <Button android:id="@+id/btnYes" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="yes" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnNo" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="no" android:textColor="#FFFFFF" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:id="@+id/SwipeDurationContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/coordinateLocking"
            app:layout_constraintStart_toStartOf="@id/statusText"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="24dp">

            <TextView
                android:id="@+id/SwipeDurationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Swipe actions duration (miliseconds)"
                android:textColor="#A0A0A0"
                android:textAllCaps="true"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/SwipeDurationToggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/Btn300">
                <Button android:id="@+id/Btn50" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="50" android:textColor="#FFFFFF" />
                <Button android:id="@+id/Btn300" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="300" android:textColor="#FFFFFF" />
                <Button android:id="@+id/Btn800" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="800" android:textColor="#FFFFFF" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <EditText
                android:id="@+id/SwipeDurationInput"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="Custom milliseconds"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#606060"
                android:backgroundTint="#20FFC4"
                android:textSize="14sp" />
        </LinearLayout>




    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
